# -------------------------------------------------------
# HSBeauty — backend/.env.example
# Copie este arquivo para .env e preencha os valores.
# NUNCA commite o arquivo .env no repositorio.
# -------------------------------------------------------

# Banco de dados (Neon/PostgreSQL)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# JWT — use pelo menos 64 caracteres aleatorios em producao
# Gerar: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET_AT_LEAST_64_CHARS

# CORS — dominios autorizados a chamar a API via navegador
# Para mais de um dominio, separe por virgula (sem espacos)
FRONTEND_URL=http://localhost:5173

# Porta local da API (padrao: 3000)
PORT=3000

# -------------------------------------------------------
# Email de confirmacao de agendamento
# Opcional — se nenhum provider configurado, envio silenciosamente ignorado.
# Prioridade: Brevo > Gmail SMTP > Resend.
# -------------------------------------------------------

# OPCAO A (recomendada para hospedagem free como Render): Brevo — API HTTP, 300 emails/dia gratis
# 1. Criar conta em https://www.brevo.com
# 2. Verificar Single Sender (seu email pessoal) em Senders & IP -> Senders -> Add a sender
# 3. Gerar API Key em SMTP & API -> API Keys
BREVO_API_KEY=
BREVO_FROM_EMAIL=
BREVO_FROM_NAME=HSBeauty Studio

# OPCAO B: Gmail SMTP — gratis, ate 500 emails/dia, NAO funciona em Render free (SMTP bloqueado)
# 1. Ativar 2FA: https://myaccount.google.com/security
# 2. Gerar senha de app (16 chars): https://myaccount.google.com/apppasswords
# 3. Configurar GMAIL_USER (seu email) + GMAIL_APP_PASSWORD (senha de app)
GMAIL_USER=seuemail@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Email que recebe NOTIFICACAO de novo agendamento (opcional)
# Se nao definido, usa GMAIL_USER como destino.
ADMIN_NOTIFICATION_EMAIL=

# OPCAO B: Resend — requer dominio proprio verificado
# Criar conta em https://resend.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# -------------------------------------------------------
# Testes de integracao com banco real
# Deixar vazios para pular os testes (skip automatico).
# Requer branch Neon isolada de staging (A-012).
# -------------------------------------------------------
DATABASE_URL_INTEGRATION=
INTEGRATION_ADMIN_EMAIL=admin@hsbeauty.com
INTEGRATION_ADMIN_PASSWORD=

# -------------------------------------------------------
# Admin — criado exclusivamente via CLI (nao existe rota HTTP)
# npm run create-admin --prefix backend -- email@exemplo.com SENHA_FORTE
# -------------------------------------------------------
