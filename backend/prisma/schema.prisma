generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Servico {
  id           Int            @id @default(autoincrement())
  nome         String         @unique
  descricao    String?
  preco        Float
  duracao      Int            // Duração em minutos
  categoriaId  Int?
  imagemUrl    String?
  ativo        Boolean        @default(true)
  criadoEm     DateTime       @default(now())
  atualizadoEm DateTime       @updatedAt

  categoria    Categoria?     @relation(fields: [categoriaId], references: [id], onDelete: SetNull)
  agendamentos Agendamento[]
  comboItens   ComboItem[]

  @@index([categoriaId])
}

model Categoria {
  id           Int       @id @default(autoincrement())
  nome         String    @unique
  imagemUrl    String?
  ordem        Int       @default(0)
  ativo        Boolean   @default(true)
  criadoEm     DateTime  @default(now())
  atualizadoEm DateTime  @updatedAt

  servicos     Servico[]
}

model Combo {
  id           Int           @id @default(autoincrement())
  nome         String        @unique
  descricao    String?
  preco        Float
  ativo        Boolean       @default(true)
  criadoEm     DateTime      @default(now())
  atualizadoEm DateTime      @updatedAt

  itens        ComboItem[]
  agendamentos Agendamento[]
}

model ComboItem {
  id        Int     @id @default(autoincrement())
  comboId   Int
  servicoId Int
  ordem     Int     @default(0)

  combo     Combo   @relation(fields: [comboId], references: [id], onDelete: Cascade)
  servico   Servico @relation(fields: [servicoId], references: [id])

  @@unique([comboId, servicoId])
}

model Agendamento {
  id           Int      @id @default(autoincrement())
  nomeCliente  String
  telefone     String
  email        String?
  data         DateTime
  hora         String   // Formato HH:mm
  servicoId    Int?
  comboId      Int?
  status       String   @default("pendente") // pendente, confirmado, cancelado, concluido
  observacoes  String?
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  servico      Servico? @relation(fields: [servicoId], references: [id], onDelete: SetNull)
  combo        Combo?   @relation(fields: [comboId], references: [id], onDelete: SetNull)

  @@index([data], map: "Agendamento_data_idx")
  @@index([status], map: "Agendamento_status_idx")
  @@index([servicoId], map: "Agendamento_servicoId_idx")
  @@index([status, data], map: "Agendamento_status_data_idx")
}

model BloqueioHorario {
  id         Int      @id @default(autoincrement())
  dataInicio DateTime
  dataFim    DateTime
  horaInicio String?  // Formato HH:mm (opcional para bloqueios de dia inteiro)
  horaFim    String?  // Formato HH:mm
  motivo     String?
  ativo      Boolean  @default(true)
  criadoEm   DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}

model SiteConfig {
  id              Int      @id @default(1)
  bannerUrl       String?
  logoUrl         String?
  aberturaHora    Int      @default(9)   // 0-23, hora de abertura local (BRT)
  fechamentoHora  Int      @default(18)  // 0-23, hora de fechamento (slot deve terminar ate aqui)
  diasFechados    Int[]    @default([])  // 0=domingo, 1=segunda, ..., 6=sabado
  atualizadoEm    DateTime @updatedAt
}

model Admin {
  id           Int            @id @default(autoincrement())
  email        String         @unique
  senha        String
  nome         String?
  ativo        Boolean        @default(true)
  criadoEm     DateTime       @default(now())
  atualizadoEm DateTime       @updatedAt

  refreshTokens RefreshToken[]
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  adminId   Int
  expiresAt DateTime
  revogado  Boolean  @default(false)
  criadoEm  DateTime @default(now())

  admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
}
