# String de conexao do banco Neon/PostgreSQL
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# Segredo JWT obrigatorio. Use uma string longa e aleatoria em producao.
JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET

# Dominios autorizados a chamar a API via navegador.
# Para mais de um dominio, separe por virgula.
FRONTEND_URL=http://localhost:5173

# Porta local da API
PORT=3000

# Admin deve ser criado via CLI:
# npm run create-admin --prefix backend -- admin@example.com CHANGE_ME_ADMIN_PASSWORD
# Nao existe registro de admin via rota HTTP em producao.

# Email de confirmacao de agendamento via Resend (https://resend.com)
# Ambas as variaveis sao opcionais. Se ausentes, o envio e silenciosamente ignorado.
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Testes de integracao (npm run test:integration --prefix backend)
# Requer banco isolado (branch Neon de staging). Deixar vazio para pular os testes.
DATABASE_URL_INTEGRATION=
INTEGRATION_ADMIN_EMAIL=
INTEGRATION_ADMIN_PASSWORD=
