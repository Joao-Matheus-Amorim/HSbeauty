# -------------------------------------------------------
# HSBeauty — frontend/.env.example
# Copie este arquivo para .env e preencha os valores.
# NUNCA commite o arquivo .env no repositorio.
# -------------------------------------------------------

# URL base da API backend (obrigatoria)
# Local: http://localhost:3000
# Producao: URL do backend publicado (Render, Railway, etc.)
VITE_API_URL=http://localhost:3000

# Numero WhatsApp da proprietaria no formato internacional (sem +)
# Usado no botao de contato da landing page
# Exemplo: 5521999999999 → (21) 99999-9999 no Brasil
VITE_WHATSAPP=5521999999999

# -------------------------------------------------------
# Cloudinary (upload de imagem dos servicos no painel admin)
# Opcional - se ausente, o painel exibe aviso e nao permite upload.
# Criar conta em https://cloudinary.com (free tier 25GB)
# Criar Upload Preset Unsigned em: Settings -> Upload -> Add upload preset
# -------------------------------------------------------
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
