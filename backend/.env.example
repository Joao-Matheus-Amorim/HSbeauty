# String de conexao do banco Neon/PostgreSQL
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# Segredo JWT obrigatorio. Use uma string longa e aleatoria em producao.
JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET

# Dominios autorizados a chamar a API via navegador.
# Para mais de um dominio, separe por virgula.
FRONTEND_URL=http://localhost:5173

# Porta local da API
PORT=3000

# Admin deve ser criado via CLI:
# npm run create-admin --prefix backend -- admin@example.com CHANGE_ME_ADMIN_PASSWORD
# Nao existe registro de admin via rota HTTP em producao.
