# String de conexão do banco Neon (PostgreSQL)
DATABASE_URL=postgresql://user:pass@ep-xxxx.neon.tech/neondb?sslmode=require

# Segredo JWT — OBRIGATÓRIO. Gere um valor forte antes de usar em produção!
# Exemplo: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=TROQUE-AQUI-POR-UM-SEGREDO-FORTE

# Admin padrão gerado pelo seed
ADMIN_EMAIL=admin@hsbeauty.com
ADMIN_SENHA=hsbeauty123

# Porta do servidor
PORT=3000

# Origens permitidas no CORS (separadas por vírgula)
# Em desenvolvimento: http://localhost:5173
# Em produção: https://seu-dominio.vercel.app
CORS_ORIGIN=http://localhost:5173
